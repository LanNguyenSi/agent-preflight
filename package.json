{
  "name": "agent-preflight",
  "version": "0.1.0",
  "description": "CI preflight validation tool for AI agents",
  "main": "dist/index.js",
  "bin": {
    "preflight": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
