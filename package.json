    "typecheck": "tsc --noEmit"
  },
  "keywords": ["ci", "preflight", "agent", "validation"],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.0.0",
    "execa": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.4.0",
    "eslint": "^10.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
