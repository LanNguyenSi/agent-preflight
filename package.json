{
  "name": "@lannguyensi/agent-preflight",
  "version": "0.1.0",
  "description": "CI preflight validation tool for AI agents",
  "main": "dist/index.js",
  "bin": {
    "preflight": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
